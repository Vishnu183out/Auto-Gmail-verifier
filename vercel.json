{
  "version": 2,

  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/api/gmailWatcher",
      "dest": "api/gmailWatcher.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/gmail-webhook.js"
    }
  ],

  "crons": [
    {
      "path": "/api/gmailWatcher",
      "schedule": "0 0 * * *"
    }
  ]
}
